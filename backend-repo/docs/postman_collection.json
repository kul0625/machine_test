{
  "info": {
    "name": "Hierarchy Wallet APIs (Complete)",
    "description": "Complete Postman collection for authentication, hierarchy, balance, and admin APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get CAPTCHA",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/captcha",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "captcha"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"owner\",\n  \"password\": \"Owner@123\",\n  \"captchaAnswer\": \"<solve_from_captcha>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Register / Create Next-Level User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Agent 1\",\n  \"username\": \"agent1\",\n  \"password\": \"Agent@123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Next-Level Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/next-level",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "next-level"
              ]
            }
          }
        },
        {
          "name": "Get Downline (self)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/downline",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "downline"
              ]
            }
          }
        },
        {
          "name": "Get Downline (specific userId)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/downline/{{targetUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "downline",
                "{{targetUserId}}"
              ]
            }
          }
        },
        {
          "name": "Change Next-Level User Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"NewPass@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{targetUserId}}/password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "{{targetUserId}}",
                "password"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Balance",
      "item": [
        {
          "name": "Owner Self Recharge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/balance/self-recharge",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "balance",
                "self-recharge"
              ]
            }
          }
        },
        {
          "name": "Transfer to Next-Level User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"{{targetUserId}}\",\n  \"amount\": 100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/balance/transfer",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "balance",
                "transfer"
              ]
            }
          }
        },
        {
          "name": "Balance Statement",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/balance/statement",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "balance",
                "statement"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Next-Level Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/next-level",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "next-level"
              ]
            }
          }
        },
        {
          "name": "Admin Hierarchy by User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/hierarchy/{{targetUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "hierarchy",
                "{{targetUserId}}"
              ]
            }
          }
        },
        {
          "name": "Admin Credit Any User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 200\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/credit/{{targetUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "credit",
                "{{targetUserId}}"
              ]
            }
          }
        },
        {
          "name": "Admin Balance Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/balance-summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "balance-summary"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Keep cookies enabled in Postman to persist auth_token + session for CAPTCHA/login flow."
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "targetUserId",
      "value": "replace_with_user_id"
    }
  ]
}